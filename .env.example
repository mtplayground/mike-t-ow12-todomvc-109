# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# HTTP server settings.
HOST="0.0.0.0"
PORT="8080"
NODE_ENV="development"

# Optional filesystem path for serving the built React SPA from Express.
# Defaults to ../client/dist relative to the server build output.
CLIENT_DIST_PATH=""

# Optional browser-facing API origin for the React SPA.
# Leave blank for same-origin requests and Vite dev proxying.
VITE_API_BASE_URL=""

# S3-compatible object storage for user-uploaded task images.
S3_ENDPOINT="https://s3.example.com"
S3_REGION="auto"
S3_BUCKET="todomvc-030-task-images"
S3_ACCESS_KEY_ID="example-access-key-id"
S3_SECRET_ACCESS_KEY="example-secret-access-key"
S3_PUBLIC_BASE_URL="https://cdn.example.com/todomvc-030-task-images"
MAX_IMAGE_BYTES="5242880"
